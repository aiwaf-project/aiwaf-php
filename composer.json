{
    "name": "aayushgauba/aiwaf",
    "description": "Adaptive Intelligent Web Application Firewall for PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
      {
        "name": "Aayush Gauba",
        "email": "gauba.aayush@gmail.com"
      }
    ],
    "require": {
      "php": ">=7.4"
    },
    "suggest": {
      "ext-redis": "Required only when using AIWAF\\Adapters\\RedisAdapter and Redis rate limit driver"
    },
    "require-dev": {
      "phpunit/phpunit": "^9.6",
        "illuminate/support": "^8.83",
        "illuminate/routing": "^8.83",
        "symfony/console": "^5.4",
        "symfony/routing": "^5.4",
        "wp-cli/wp-cli-bundle": "^2.9",
        "illuminate/console": "^8.83"
    },
    "autoload": {
        "psr-4": {
            "AIWAF\\": "src/"
        }
    },
    "autoload-dev": {
      "psr-4": {
        "AIWAF\\Tests\\": "tests/"
      }
    },
    "archive": {
      "exclude": [
        "/examples",
        "/tools"
      ]
    },
    "scripts": {
      "test": "phpunit --colors=always",
      "cover-everything": "php tools/cover-everything.php",
      "test-adapters-matrix": "php tools/test-adapters-matrix.php",
      "validate-all": "php tools/validate-all.php"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
  }
